#=============================================================================
# yosys synthesis for jpeg_axi_top targeting ASAP7 7.5T RVT TT cells.
#
# Memories kept as $mem_v2 (memory -nomap) — costed separately via
# asap7_mem_area.py.  Inference sources:
#   * line_buffer.v           (Y 16×MAX_W + Cb/Cr 8×MAX_W/2)
#   * mcu_buffer.v            (16×16 Y + 8×8 Cb + 8×8 Cr)
#   * htable_ram.v            (BITS / mincode / maxcode / valptr / huffval)
#   * qtable_ram.v            (4 × 64B)
#   * axi_stream_fifo.v       (byte FIFO × 2, depth 32)
#
# All inputs are Verilog-2001; `include` pulled in via -I switch.
#=============================================================================

read_verilog -nomem2reg -I../../rtl/include \
    ../../rtl/src/axi_lite_slave.v \
    ../../rtl/src/axi_stream_fifo.v \
    ../../rtl/src/bitstream_unpack.v \
    ../../rtl/src/block_sequencer.v \
    ../../rtl/src/chroma_upsample.v \
    ../../rtl/src/dc_predictor.v \
    ../../rtl/src/dequant_izz.v \
    ../../rtl/src/header_parser.v \
    ../../rtl/src/htable_ram.v \
    ../../rtl/src/huffman_decoder.v \
    ../../rtl/src/idct_1d.v \
    ../../rtl/src/idct_2d.v \
    ../../rtl/src/line_buffer.v \
    ../../rtl/src/mcu_buffer.v \
    ../../rtl/src/mcu_line_copy.v \
    ../../rtl/src/pixel_out.v \
    ../../rtl/src/qtable_ram.v \
    ../../rtl/src/jpeg_axi_top.v

hierarchy -top jpeg_axi_top -check

proc
flatten
opt -fast
fsm
opt
memory -nomap
opt
wreduce
opt_expr -mux_undef
opt_clean -purge
techmap
opt -fast

dfflibmap -liberty ../asap7/asap7_merged_RVT_TT.lib
abc -liberty ../asap7/asap7_merged_RVT_TT.lib -D 1667 \
    -script "+strash;map -D 1667;topo;buffer -N 16;upsize -D 1667;dnsize -D 1667;stime -p -c"

setundef -zero -undriven
opt_clean -purge

stat -width -liberty ../asap7/asap7_merged_RVT_TT.lib

write_verilog -noattr ../reports/jpeg_axi_top_netlist.v
